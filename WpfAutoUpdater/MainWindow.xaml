<Window x:Class="WpfAutoUpdater.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="오토 업데이트"
        Height="520" Width="650"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#1E5B9A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2E6BB0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#164778"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#A0A0A0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="10" Background="White" BorderBrush="#1E5B9A" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Color="#40000000" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="140"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 헤더 -->
            <Border Grid.Row="0" CornerRadius="10,10,0,0" Background="#1E5B9A">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="80"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="최신 업데이트를 시작합니다."
                               FontFamily="Segoe UI" FontSize="28" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center" Margin="20,0"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="20,0">
                        <TextBlock Text="프로그램: " FontFamily="Segoe UI" FontSize="12" Foreground="#B0B0B0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="lblProgramName" Text="POPs_Renewal"
                                  FontFamily="Segoe UI" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock Text="  |  버전: " FontFamily="Segoe UI" FontSize="12" Foreground="#B0B0B0" VerticalAlignment="Center" Margin="15,0,0,0"/>
                        <TextBlock x:Name="lblVersion" Text="1.0.0.1"
                                  FontFamily="Segoe UI" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock x:Name="lblModifyDate" Text="2026-04-23" FontFamily="Segoe UI" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="15,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 컨텐츠 -->
            <Border Grid.Row="1" Background="White" Margin="20,20">
                <StackPanel>
                    <TextBlock x:Name="lblFileName" Text="다운로드 준비"
                             FontFamily="Segoe UI" FontSize="11" Foreground="#666666"/>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ProgressBar x:Name="pbAll" Minimum="0" Maximum="100" Value="0"
                                   Height="18" Background="#E8E8E8" Foreground="#1E5B9A"/>
                        <TextBlock x:Name="lblCount" Grid.Column="1" Text="0/0"
                                   FontFamily="Segoe UI" FontSize="11" FontWeight="Bold"
                                   Foreground="#1E5B9A" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </Grid>

                    <TextBlock x:Name="lblFileCheck" Text="체크 준비"
                             FontFamily="Segoe UI" FontSize="10" Foreground="#888888" Margin="0,15,0,0"/>

                    <ProgressBar x:Name="pbThis" Minimum="0" Maximum="100" Value="0"
                                 Height="14" Background="#F0F0F0" Foreground="#4CAF50" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- 하단 -->
            <Border Grid.Row="2" Background="#F5F5F5" CornerRadius="0,0,10,10" Padding="20,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                        <CheckBox x:Name="chkAutoRun" Content="업데이트 후 자동 실행" IsChecked="True"
                                 FontFamily="Segoe UI" FontSize="11"/>
                        <TextBlock x:Name="lblAutoRunTarget" Text="(실행 파일: POPs_Renewal.exe)" 
                                 FontFamily="Segoe UI" FontSize="9" Foreground="#888888" Margin="20,2,0,0"/>
                    </StackPanel>

                    <Button x:Name="btnSettings" Grid.Column="2" Content="환경설정"
                            Style="{StaticResource ModernButton}"/>
                    <Button x:Name="btnUpdate" Grid.Column="3" Content="업데이트 시작"
                            Background="#28a745" Style="{StaticResource ModernButton}" Margin="10,0,0,0" Click="btnUpdate_Click"/>
                    <Button x:Name="btnCancel" Grid.Column="4" Content="종료"
                            Style="{StaticResource ModernButton}" Margin="10,0,0,0" Click="btnCancel_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>