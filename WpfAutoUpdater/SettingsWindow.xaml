<Window x:Class="WpfAutoUpdater.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="환경설정"
        Height="420" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#1E5B9A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- FTP 서버 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="FTP 서버 주소" FontFamily="Segoe UI" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtFtpServer" FontFamily="Segoe UI" Padding="8"/>
        </StackPanel>

        <!-- FTP 포트 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="FTP 포트" FontFamily="Segoe UI" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtFtpPort" FontFamily="Segoe UI" Padding="8" Text="21"/>
        </StackPanel>

        <!-- 사용자 -->
        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="FTP 사용자" FontFamily="Segoe UI" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtFtpUser" FontFamily="Segoe UI" Padding="8"/>
        </StackPanel>

        <!-- 암호 -->
        <StackPanel Grid.Row="3" Margin="0,0,0,15">
            <TextBlock Text="FTP 암호" FontFamily="Segoe UI" FontWeight="Bold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtFtpPass" FontFamily="Segoe UI" Padding="8"/>
        </StackPanel>

        <!-- 프로그램 경로 -->
        <StackPanel Grid.Row="4" Margin="0,0,0,15">
            <TextBlock Text="업데이트 소스 경로 (FTP/URL)" FontFamily="Segoe UI" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtProgramPath" FontFamily="Segoe UI" Padding="8"/>
        </StackPanel>

        <!-- 실행 파일 설정 추가 -->
        <StackPanel Grid.Row="5" Margin="0,0,0,15">
            <TextBlock Text="업데이트 후 실행할 파일명 (예: MainApp.exe)" FontFamily="Segoe UI" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtExeName" FontFamily="Segoe UI" Padding="8"/>
        </StackPanel>

        <!-- 버튼 -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="저장" Style="{StaticResource ModernButton}" Click="btnSave_Click"/>
            <Button Content="닫기" Background="#888888" Style="{StaticResource ModernButton}" Margin="10,0,0,0" Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>